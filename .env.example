# Mot de passe PostgreSQL — à changer en production
DB_PASSWORD=changeme

# Secret HMAC de signature des jetons d'authentification — OBLIGATOIRE.
# L'application refuse de démarrer s'il n'est pas défini.
# Sert aussi à DÉRIVER la clé de chiffrement des secrets stockés en base
# (mot de passe FTP chiffré au repos en AES-256-GCM). Ne le changez pas après
# avoir enregistré une config FTP, sinon le mot de passe ne sera plus déchiffrable.
# Générez-en un fort, par ex. : openssl rand -base64 48
APP_AUTH_SECRET=

# Origines autorisées pour le CORS (liste séparée par des virgules).
# Vide par défaut : aucune origine croisée autorisée (le frontend Nginx est
# servi sur la même origine que l'API, donc CORS inutile). À renseigner
# UNIQUEMENT si vous appelez l'API depuis un autre domaine.
# Exemple : APP_CORS_ALLOWED_ORIGINS=https://scanner.exemple.com
APP_CORS_ALLOWED_ORIGINS=

# Compte admin créé au premier démarrage (si aucun utilisateur n'existe).
# À changer immédiatement après le premier login.
APP_ADMIN_USER=admin
APP_ADMIN_PASSWORD=admin
